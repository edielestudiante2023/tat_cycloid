#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------

CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'http://localhost/tat_cycloid/public/'

#--------------------------------------------------------------------
# CACHE
#--------------------------------------------------------------------

cache.storePath = '/tmp/tat_cycloid_cache'

#--------------------------------------------------------------------
# DATABASE — Conexion principal
#--------------------------------------------------------------------

database.default.hostname = localhost
database.default.database = tat_cycloid
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

# Para DigitalOcean Managed MySQL (produccion):
# database.default.hostname = host-del-cluster.db.ondigitalocean.com
# database.default.port = 25060
# database.default.encrypt = TRUE

#--------------------------------------------------------------------
# DATABASE — Conexion readonly (portal cliente / Chat Otto)
#--------------------------------------------------------------------
# Usuario con permisos SELECT-only sobre vistas v_* y tablas maestras.
# Fisicamente incapaz de INSERT / UPDATE / DELETE / DROP.

# readonly.hostname = localhost
# readonly.database = tat_cycloid
# readonly.username = cycloid_readonly
# readonly.password =
# readonly.port = 3306

#--------------------------------------------------------------------
# DATABASE — Produccion (DigitalOcean Managed MySQL)
#--------------------------------------------------------------------
# Solo necesario si ejecutas scripts de migracion o Commands
# que conectan directamente a la BD de produccion.

# database.production.hostname = host-del-cluster.db.ondigitalocean.com
# database.production.database = tat_cycloid
# database.production.username = cycloid_userdb
# database.production.password =
# database.production.DBDriver = MySQLi
# database.production.port = 25060

#--------------------------------------------------------------------
# API KEYS — Email transaccional (SendGrid)
#--------------------------------------------------------------------

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=notificacion.cycloidtalent@cycloidtalent.com
SENDGRID_FROM_NAME=Cycloid TAT

#--------------------------------------------------------------------
# API KEYS — OpenAI (Chat Otto, generacion de textos)
#--------------------------------------------------------------------

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

#--------------------------------------------------------------------
# API KEYS — Anthropic (clasificacion de PDFs)
#--------------------------------------------------------------------

# ANTHROPIC_API_KEY=

#--------------------------------------------------------------------
# TOKENS INTERNOS
#--------------------------------------------------------------------

# Token para endpoints API internos (ApiKeyFilter)
APP_API_KEY=

# Token para endpoints cron via HTTP (ContractController)
CRON_TOKEN=changeme

#--------------------------------------------------------------------
# RUTAS
#--------------------------------------------------------------------

# Ruta de uploads de clientes (fuera de git)
# UPLOADS_PATH = /www/soportes-clientes/
