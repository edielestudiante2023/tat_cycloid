*.tmlanguage.cache
*.tmPreferences.cache
*.stTheme.cache
*.sublime-workspace
*.sublime-project
.phpintel
/api/

# Visual Studio Code
.vscode/

# Claude settings (contiene secrets de producción)
.claude/settings.json

# Scripts utilitarios con credenciales (solo uso local)
app/Commands/ReplicateDbStructure.php
app/Commands/ReplicateToTat.php
app/Commands/CopyConsultores.php
app/Commands/CopyUsuarios.php
app/Commands/CreateUsuariosConsultores.php
app/Commands/CopyCatalogos.php
tools/cargar_pdfs_produccion.php
tools/clasificar_pdfs.php
tools/reparar_nombres_v2.php
tools/reparar_nombres_archivos.php
app/SQL/query_pta_indicadores.php

/results/
/phpunit*.xml

# Ignorar archivos de configuración específicos
app/Config/App.php
app/Config/Database.php

sendgrid.envsendgrid.env

composer.lock
composer.json
nul

